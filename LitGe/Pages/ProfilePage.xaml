                        Text="პირადი ინფორმაცია"
                        TextColor="{DynamicResource DarkerTextColor}"
                        VerticalTextAlignment="Center" />

                    <Image
                        Grid.Column="2"
                        HeightRequest="18"
                        Source="chevron_right.svg"
                        WidthRequest="18" />
                </Grid>

                <Grid ColumnDefinitions="*,4*,*">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ChangePasswordCommand}" />
                    </Grid.GestureRecognizers>

                    <Grid.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultAnimationDuration="100"
                            DefaultAnimationEasing="{x:Static Easing.CubicInOut}"
                            PressedOpacity="0.6"
                            PressedScale="0.95" />
                    </Grid.Behaviors>

                    <toolkit:AvatarView
                        Grid.Column="0"
                        Padding="17,20"
                        BackgroundColor="{DynamicResource Background}"
                        CornerRadius="50"
                        HeightRequest="69"
                        ImageSource="password.svg"
                        WidthRequest="69" />

                    <Label
                        Grid.Column="1"
                        Padding="15,0,0,0"
                        FontAttributes="Bold"
                        FontAutoScalingEnabled="False"
                        FontSize="Medium"
                        Text="პაროლის შეცვლა"
                        TextColor="{DynamicResource DarkerTextColor}"
                        VerticalTextAlignment="Center" />

                    <Image
                        Grid.Column="2"
                        HeightRequest="18"
                        Source="chevron_right.svg"
                        WidthRequest="18" />
                </Grid>
            </VerticalStackLayout>-->
        </Grid>
    </Grid>
</ContentPage>